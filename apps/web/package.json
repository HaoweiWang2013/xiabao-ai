{
  "name": "@xiabao/web",
  "version": "0.0.1",
  "private": true,
  "description": "XiabaoAI Web (SPA + local fastify server)",
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "scripts": {
    "dev": "run-p dev:server dev:web",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "run-s build:web build:server",
    "build:web": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "start": "node dist-server/index.js",
    "clean": "rimraf dist dist-server .turbo",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xiabao/core": "workspace:*",
    "@xiabao/server": "workspace:*",
    "@xiabao/app-ui": "workspace:*",
    "@xiabao/state": "workspace:*",
    "@xiabao/theme": "workspace:*",
    "@xiabao/ui": "workspace:*",
    "@xiabao/i18n": "workspace:*",
    "@xiabao/crypto": "workspace:*",
    "@libsql/client": "0.10.0",
    "@tanstack/react-query": "4.36.1",
    "@trpc/client": "10.45.2",
    "@trpc/react-query": "10.45.2",
    "@trpc/server": "10.45.2",
    "@fastify/cors": "9.0.1",
    "@fastify/static": "7.0.4",
    "fastify": "4.28.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "jotai": "2.9.1",
    "lucide-react": "0.424.0",
    "clsx": "2.1.1",
    "pino": "9.3.2",
    "superjson": "2.2.1",
    "tailwind-merge": "2.4.0",
    "ws": "8.18.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.11",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/ws": "8.5.10",
    "@vitejs/plugin-react": "4.3.1",
    "@xiabao/tsconfig": "workspace:*",
    "autoprefixer": "10.4.19",
    "npm-run-all2": "6.2.2",
    "postcss": "8.4.40",
    "rimraf": "5.0.9",
    "tailwindcss": "3.4.7",
    "tsx": "4.16.5",
    "typescript": "5.5.4",
    "vite": "5.3.5"
  }
}
