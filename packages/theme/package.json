{
  "name": "@xiabao/theme",
  "version": "0.0.1",
  "private": true,
  "description": "Design tokens + Tailwind preset + CSS variables",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tailwind-preset": "./src/tailwind-preset.ts",
    "./css-variables": "./src/css-variables.css",
    "./highlight": "./src/highlight.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@xiabao/tsconfig": "workspace:*",
    "rimraf": "5.0.9",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4"
  }
}
