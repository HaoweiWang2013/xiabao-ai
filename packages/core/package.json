{
  "name": "@xiabao/core",
  "version": "0.0.1",
  "private": true,
  "description": "Platform-agnostic business logic for XiabaoAI (Providers, Services, Ports, Models)",
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "default": "./dist/ports/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "3.23.8",
    "nanoid": "5.0.7"
  },
  "devDependencies": {
    "@xiabao/tsconfig": "workspace:*",
    "rimraf": "5.0.9",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
