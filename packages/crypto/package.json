{
  "name": "@xiabao/crypto",
  "version": "0.0.1",
  "private": true,
  "description": "End-to-end encryption utilities (AES-GCM + Argon2id / HKDF)",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@noble/ciphers": "0.5.3",
    "@noble/hashes": "1.4.0"
  },
  "devDependencies": {
    "@xiabao/tsconfig": "workspace:*",
    "rimraf": "5.0.9",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
