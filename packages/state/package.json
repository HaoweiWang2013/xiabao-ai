{
  "name": "@xiabao/state",
  "version": "0.0.1",
  "private": true,
  "description": "Jotai atoms for XiabaoAI",
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@xiabao/core": "workspace:*",
    "jotai": "2.9.1"
  },
  "devDependencies": {
    "@xiabao/tsconfig": "workspace:*",
    "rimraf": "5.0.9",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
