{
  "name": "@xiabao/ui-native",
  "version": "0.0.1",
  "private": true,
  "description": "React Native components for XiabaoAI (NativeWind + RN primitives)",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-native": ">=0.74.0"
  },
  "dependencies": {
    "@xiabao/core": "workspace:*",
    "@xiabao/state": "workspace:*",
    "@xiabao/theme": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "18.3.3",
    "@xiabao/tsconfig": "workspace:*",
    "nativewind": "4.1.23",
    "react": "18.3.1",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.9",
    "rimraf": "5.0.9",
    "typescript": "5.5.4"
  }
}
