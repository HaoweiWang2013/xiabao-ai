{
  "name": "@xiabao/server",
  "version": "0.0.1",
  "private": true,
  "description": "Platform-agnostic server-side business logic: db schema, repos, services, tRPC routers",
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./trpc": {
      "types": "./dist/trpc/index.d.ts",
      "default": "./dist/trpc/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./repos": {
      "types": "./dist/repos/index.d.ts",
      "default": "./dist/repos/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "migrations"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@libsql/client": "0.10.0",
    "@trpc/server": "10.45.2",
    "@xiabao/core": "workspace:*",
    "@xiabao/crypto": "workspace:^",
    "drizzle-orm": "0.33.0",
    "mammoth": "^1.8.0",
    "officeparser": "^5.1.1",
    "pdfjs-dist": "^4.10.38",
    "superjson": "2.2.1",
    "tesseract.js": "^5.1.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.11",
    "@xiabao/tsconfig": "workspace:*",
    "drizzle-kit": "0.24.2",
    "rimraf": "5.0.9",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
