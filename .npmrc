auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-frozen-lockfile=true
enable-pre-post-scripts=true
# Electron 原生模块
node-linker=isolated
public-hoist-pattern[]=*electron*
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-native-community/*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=react-native-gesture-handler
public-hoist-pattern[]=react-native-reanimated
public-hoist-pattern[]=react-native-safe-area-context
public-hoist-pattern[]=react-native-screens

# ── 国内镜像加速 ────────────────────────────────────────────────────────────
# 默认 npm 源
registry=https://registry.npmjs.org/

# 大文件镜像（pnpm 会读这些 *_mirror 配置传给安装脚本）
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
sass_binary_site=https://npmmirror.com/mirrors/node-sass/
puppeteer_download_host=https://npmmirror.com/mirrors
chromedriver_cdnurl=https://npmmirror.com/mirrors/chromedriver
operadriver_cdnurl=https://npmmirror.com/mirrors/operadriver
sharp_dist_base_url=https://npmmirror.com/mirrors/sharp
phantomjs_cdnurl=https://npmmirror.com/mirrors/phantomjs
sqlite3_binary_host_mirror=https://foxgis.oss-cn-shanghai.aliyuncs.com/
better_sqlite3_binary_host_mirror=https://npmmirror.com/mirrors/better-sqlite3
node_sqlite3_binary_host_mirror=https://npmmirror.com/mirrors

# 取消 wrangler 自动 telemetry / metrics（可选）
wrangler_send_metrics=false
